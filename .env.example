# Anthropic API key (Worker 3 — Claude classification)
ANTHROPIC_API_KEY=sk-ant-...

# Serper API key (Worker 3 — adverse media search)
SERPER_API_KEY=...

# Opendatabot API key (Worker 1 — держреєстри + санкції)
OPENDATABOT_API_KEY=...

# --- Веб-інтерфейс (:8000) ---
# Пароль на веб. Якщо не заданий — доступ відкритий (зручно локально).
# Для команди: задай пароль, і колеги заходитимуть за логіном/паролем.
KYC_WEB_USER=kyc
KYC_WEB_PASSWORD=

# Scraper settings
SCRAPER_DELAY_SECONDS=2
SCRAPER_USER_AGENT=kyc-network-scout/1.0 (educational; contact: your-email@example.com)

# --- Ліміти веб-сервісу (необов'язкові, мають дефолти) ---
# KYC_MAX_INFLIGHT=12   # макс. одночасних перевірок (захист API-кредитів)
# KYC_MAX_JOBS=1000     # кап in-memory стору задач
